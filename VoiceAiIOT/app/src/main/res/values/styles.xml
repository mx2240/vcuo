<resources>
    <!-- Base application theme. -->
    <!-- ... your existing theme ... -->

    <!-- ========================================================== -->
    <!-- Style for Device Cards (Home Fragment)                     -->
    <!-- ========================================================== -->
    <style name="DeviceCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">8dp</item>
        <item name="cardBackgroundColor">#1AFFFFFF</item> <!-- glass_white -->
        <item name="strokeColor">#33FFFFFF</item> <!-- glass_border -->
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">20dp</item>
    </style>

    <style name="DeviceCard.Content" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="DeviceCard.Title" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="DeviceCard.Value" parent="DeviceCard.Title">
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:textColor">#00E5FF</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DeviceCard.Switch" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <!-- ========================================================== -->
    <!-- Styles for Profile Fragment                                -->
    <!-- ========================================================== -->

    <!-- Circle Image shape for ShapeableImageView -->
    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Style for the Rows in the Settings List -->
    <style name="ProfileMenuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:drawablePadding">16dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Style for the horizontal lines between settings -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">56dp</item>
        <item name="android:background">#1AFFFFFF</item>
    </style>

</resources>