<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Cloud Backup configuration (Google Drive) -->
    <cloud-backup>
        <!-- By default, all app data is included.
             Add <exclude> tags here if you have sensitive data like passwords
             or large files you don't want to back up. -->
        <include domain="sharedpref" path="."/>
        <include domain="database" path="."/>
    </cloud-backup>

    <!-- Device-to-device transfer configuration (e.g., using a cable) -->
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <include domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>